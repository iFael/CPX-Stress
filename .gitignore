# ==================================================
# StressFlow - .gitignore
# ==================================================

# --------------------------------------------------
# Dependencias (pacotes instalados pelo npm/yarn/pnpm)
# --------------------------------------------------
node_modules
.pnp
.pnp.js
.yarn/

# --------------------------------------------------
# Arquivos de build e compilacao
# --------------------------------------------------
dist
dist-electron
out

# --------------------------------------------------
# Saida do electron-builder (instaladores e pacotes)
# --------------------------------------------------
release
release/

# --------------------------------------------------
# Cache de ferramentas de build e bundlers
# --------------------------------------------------
.vite
.tsbuildinfo
*.tsbuildinfo

# --------------------------------------------------
# Arquivos de ambiente e configuracoes sensiveis
# --------------------------------------------------
.env
.env.*
*.local

# --------------------------------------------------
# Logs e arquivos de depuracao
# --------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --------------------------------------------------
# Arquivos de sistema operacional
# --------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# --------------------------------------------------
# Arquivos de IDEs e editores de codigo
# --------------------------------------------------

# Visual Studio Code
.vscode/

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim

# --------------------------------------------------
# Arquivos de teste e cobertura de codigo
# --------------------------------------------------
coverage
*.lcov
.nyc_output

# --------------------------------------------------
# Diversos (arquivos temporarios e outros)
# --------------------------------------------------
*.pid
*.seed
*.pid.lock
.cache
.temp
.tmp

# --------------------------------------------------
# Claude Code (configuracoes locais do agente)
# --------------------------------------------------
.claude/
