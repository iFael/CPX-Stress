{
  "name": "cpx-stress",
  "version": "1.0.0",
  "description": "CPX-Stress - Ferramenta profissional de teste de estresse para APIs e servidores web. / Professional stress testing tool for APIs and web servers.",
  "main": "dist-electron/main.js",
  "private": true,
  "author": {
    "name": "Rafael Damasio"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iFael/CPX-Stress.git"
  },
  "homepage": "https://github.com/iFael/CPX-Stress#readme",
  "bugs": {
    "url": "https://github.com/iFael/CPX-Stress/issues"
  },
  "keywords": [
    "stress-test",
    "load-test",
    "performance",
    "api-testing",
    "http",
    "benchmark",
    "electron",
    "react",
    "typescript",
    "teste-de-estresse",
    "teste-de-carga"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build:worker": "esbuild electron/engine/stress-worker.ts --bundle --platform=node --target=es2022 --format=cjs --outfile=dist-electron/stress-worker.js --external:better-sqlite3",
    "dev": "npm run build:worker && vite",
    "build": "tsc && vite build && npm run build:worker",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"audit/**/*.ts\" \"scripts/**/*.ts\" \"vite.config.ts\" --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"audit/**/*.ts\" \"scripts/**/*.ts\" \"vite.config.ts\" --fix",
    "format": "prettier --write \"{src,electron,audit,scripts}/**/*.{ts,tsx,css,json,js,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"{src,electron,audit,scripts}/**/*.{ts,tsx,css,json,js,md}\" \"*.{json,md}\"",
    "audit:ssrf": "tsx audit/test-ssrf.ts",
    "audit:engine": "tsx scripts/run-audit-with-mock.ts audit/engine-test-harness.ts",
    "audit:convergence": "tsx scripts/run-audit-with-mock.ts audit/benchmark-convergence-harness.ts",
    "audit:mistert": "tsx audit/mistert-validation.ts",
    "audit:extreme": "tsx scripts/run-audit-with-mock.ts audit/stress-extreme-test.ts",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm run build && npm run audit:ssrf && npm run audit:engine",
    "clean": "rimraf dist dist-electron",
    "rebuild": "npm run clean && npm run build",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "postinstall": "node scripts/install-native.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.0",
    "date-fns": "^3.6.0",
    "html-to-image": "^1.11.11",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.3",
    "uuid": "^9.0.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.4.14",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
